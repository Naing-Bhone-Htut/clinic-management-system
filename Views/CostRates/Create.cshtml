@model CostRate
@{ ViewData["Title"] = "Add Cost Rate"; }
<form asp-action="Create" method="post" class="card p-4 shadow-sm col-md-6">
<partial name="_CostRateForm" model="Model" />
<div class="form-actions d-flex flex-wrap align-items-center mt-4 pt-3 border-top">
    <button class="btn btn-primary" type="submit">Save Cost Rate</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</div>
</form>
@section Scripts{<partial name="_ValidationScriptsPartial"/>}
