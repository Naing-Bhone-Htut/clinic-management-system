@model BillFormViewModel
@{ ViewData["Title"] = "Create Expense Bill"; }
<form asp-action="CreateExpense" method="post" class="card p-4 shadow-sm">
    <div asp-validation-summary="All" class="alert alert-danger"></div>
    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <label asp-for="BillDate" class="form-label"></label>
            <input asp-for="BillDate" type="date" class="form-control" title="e.g. today's date" />
        </div>
        <div class="col-md-8">
            <label asp-for="Description" class="form-label"></label>
            <input asp-for="Description" class="form-control" placeholder="e.g. Monthly utilities payment" />
        </div>
    </div>

    <h6 class="mt-2 mb-3">Bill Items</h6>
    <div class="row g-2 mb-2 text-muted small fw-semibold d-none d-md-flex">
        <div class="col-md-5">Expense item</div>
        <div class="col-md-2">Quantity</div>
        <div class="col-md-3">Unit price</div>
        <div class="col-md-2"></div>
    </div>

    <div id="items">
        @for (int i = 0; i < Model.Items.Count; i++)
        {
            <div class="row g-2 mb-3 item-row align-items-end">
                <div class="col-md-5">
                    <label class="form-label d-md-none">Expense item</label>
                    <select name="Items[@i].CostRateId" class="form-select">
                        <option value="">-- Select expense item --</option>
                        @foreach (var c in Model.CostRates)
                        {
                            <option value="@c.Value">@c.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label d-md-none">Quantity</label>
                    <input name="Items[@i].Quantity" value="@Model.Items[i].Quantity" type="number" min="1" class="form-control" placeholder="e.g. 1" />
                </div>
                <div class="col-md-3">
                    <label class="form-label d-md-none">Unit price</label>
                    <input name="Items[@i].UnitPrice" value="@Model.Items[i].UnitPrice" type="number" step="0.01" min="0" class="form-control" placeholder="0 = default" />
                </div>
                <div class="col-md-2 d-flex pb-1">
                    <button type="button" class="btn btn-outline-danger btn-sm remove-item-btn w-100">Remove</button>
                </div>
            </div>
        }
    </div>

    <template id="item-row-template">
        <div class="row g-2 mb-3 item-row align-items-end">
            <div class="col-md-5">
                <label class="form-label d-md-none">Expense item</label>
                <select name="Items[__index__].CostRateId" class="form-select">
                    <option value="">-- Select expense item --</option>
                    @foreach (var c in Model.CostRates)
                    {
                        <option value="@c.Value">@c.Text</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label d-md-none">Quantity</label>
                <input name="Items[__index__].Quantity" value="1" type="number" min="1" class="form-control" placeholder="e.g. 1" />
            </div>
            <div class="col-md-3">
                <label class="form-label d-md-none">Unit price</label>
                <input name="Items[__index__].UnitPrice" value="0" type="number" step="0.01" min="0" class="form-control" placeholder="0 = default" />
            </div>
            <div class="col-md-2 d-flex pb-1">
                <button type="button" class="btn btn-outline-danger btn-sm remove-item-btn w-100">Remove</button>
            </div>
        </div>
    </template>

    <div class="form-actions d-flex flex-wrap align-items-center gap-2 mt-4 pt-3 border-top">
        <button type="button" class="btn btn-outline-secondary" id="add-item-btn">
            <i class="bi bi-plus-lg"></i> Add Item
        </button>
        <button type="submit" class="btn btn-primary px-4">Create Bill</button>
        <a asp-action="ExpenseIndex" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <script>
        (function () {
            const container = document.getElementById('items');
            const template = document.getElementById('item-row-template');
            const addBtn = document.getElementById('add-item-btn');

            function reindexRows() {
                container.querySelectorAll('.item-row').forEach((row, index) => {
                    row.querySelectorAll('[name]').forEach(el => {
                        el.name = el.name.replace(/Items\[\d+\]/, 'Items[' + index + ']');
                    });
                });
            }

            function addRow() {
                const index = container.querySelectorAll('.item-row').length;
                const row = template.content.querySelector('.item-row').cloneNode(true);
                row.querySelectorAll('[name]').forEach(el => {
                    el.name = el.name.replace('__index__', index);
                });
                container.appendChild(row);
                bindRemove(row.querySelector('.remove-item-btn'));
            }

            function bindRemove(btn) {
                if (!btn) return;
                btn.addEventListener('click', function () {
                    if (container.querySelectorAll('.item-row').length <= 1) {
                        alert('At least one bill item is required.');
                        return;
                    }
                    btn.closest('.item-row').remove();
                    reindexRows();
                });
            }

            addBtn.addEventListener('click', addRow);
            container.querySelectorAll('.remove-item-btn').forEach(bindRemove);
        })();
    </script>
}


