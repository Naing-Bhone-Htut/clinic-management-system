@{ ViewData["Title"] = "Upload Clinic Document"; }
<form asp-action="Upload" method="post" enctype="multipart/form-data" class="card p-4 shadow-sm col-md-6">
<div class="mb-3"><label class="form-label">Title</label><input name="title" class="form-control" required placeholder="e.g. Clinic License 2026" /></div>
<div class="mb-3"><label class="form-label">Description</label><input name="description" class="form-control" placeholder="e.g. Annual operating license copy" /></div>
<div class="mb-3"><label class="form-label">File</label><input type="file" name="file" class="form-control" required title="e.g. PDF, DOCX, or image" /></div>
<div class="form-actions d-flex flex-wrap align-items-center mt-4 pt-3 border-top">
    <button class="btn btn-primary" type="submit">Upload Document</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</div>
</form>
