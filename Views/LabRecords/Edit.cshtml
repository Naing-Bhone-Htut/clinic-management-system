@model LabRecord
@{ ViewData["Title"] = "Edit Lab Record"; }
<form asp-action="Edit" method="post" enctype="multipart/form-data" class="card p-4 shadow-sm">
<input type="hidden" asp-for="LabRecordId" />
<partial name="_LabForm" />
<div class="form-actions d-flex flex-wrap align-items-center mt-4 pt-3 border-top">
    <button class="btn btn-primary" type="submit">Update Lab Record</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</div>
</form>
@section Scripts{<partial name="_ValidationScriptsPartial"/>}
