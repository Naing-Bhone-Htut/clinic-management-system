@model CheckInFormViewModel
@{ ViewData["Title"] = "Edit Check-In"; }
<form asp-action="Edit" method="post" class="card p-4 shadow-sm">
<input type="hidden" asp-for="CheckInId" />
<partial name="_CheckInForm" model="Model" />
<div class="form-actions d-flex flex-wrap align-items-center mt-4 pt-3 border-top">
    <button class="btn btn-primary" type="submit">Update Check-In</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</div>
</form>
@section Scripts{<partial name="_ValidationScriptsPartial"/>}
