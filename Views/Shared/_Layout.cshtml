@{
    var role = Context.Session.GetRole() ?? "";
    var fullName = Context.Session.GetString(SessionKeys.FullName) ?? "User";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Clinic Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="d-flex" id="wrapper">
    <nav class="sidebar bg-dark text-white p-3">
        <h5 class="text-center mb-4"><i class="bi bi-hospital"></i> Clinic CMS</h5>
        <ul class="nav flex-column">
            <li class="nav-item"><a class="nav-link text-white" asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
            @if (role is "Admin" or "Operator" or "Nurse" or "Doctor")
            {
                <li class="nav-item"><a class="nav-link text-white" asp-controller="Patients" asp-action="Index"><i class="bi bi-people"></i> Patients</a></li>
            }
            @if (role is "Admin" or "Operator" or "Nurse" or "Doctor")
            {
                <li class="nav-item"><a class="nav-link text-white" asp-controller="CheckIn" asp-action="Index"><i class="bi bi-box-arrow-in-right"></i> Check-In</a></li>
            }
            @if (role is "Admin" or "Operator")
            {
                <li class="nav-item"><a class="nav-link text-white" asp-controller="Billing" asp-action="IncomeIndex"><i class="bi bi-cash-coin"></i> Income Bills</a></li>
                <li class="nav-item"><a class="nav-link text-white" asp-controller="Billing" asp-action="ExpenseIndex"><i class="bi bi-wallet2"></i> Expense Bills</a></li>
                <li class="nav-item"><a class="nav-link text-white" asp-controller="CostRates" asp-action="Index"><i class="bi bi-tags"></i> Cost Rates</a></li>
            }
            @if (role is "Admin" or "Operator" or "Doctor" or "Nurse")
            {
                <li class="nav-item"><a class="nav-link text-white" asp-controller="LabRecords" asp-action="Index"><i class="bi bi-clipboard2-pulse"></i> Lab Records</a></li>
                <li class="nav-item"><a class="nav-link text-white" asp-controller="ClinicDocuments" asp-action="Index"><i class="bi bi-folder"></i> Clinic Documents</a></li>
            }
            @if (role == "Admin")
            {
                <li class="nav-item"><a class="nav-link text-white" asp-controller="Staff" asp-action="Index"><i class="bi bi-person-badge"></i> Staff & Users</a></li>
            }
        </ul>
    </nav>
    <div class="flex-grow-1">
        <header class="topbar border-bottom px-4 py-2 d-flex justify-content-between align-items-center bg-white">
            <span class="fw-semibold">@ViewData["Title"]</span>
            <div class="d-flex align-items-center gap-3">
                <span class="badge bg-primary">@role</span>
                <span>@fullName</span>
                <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger btn-sm">Logout</a>
            </div>
        </header>
        <main class="p-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>




