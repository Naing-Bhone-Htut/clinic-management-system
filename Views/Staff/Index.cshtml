@model IEnumerable<User>
@{ ViewData["Title"] = "Staff & Users"; }

<div class="page-toolbar">
    <div></div>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-person-plus"></i> Add Staff & User</a>
</div>

<div class="table-responsive shadow-sm">
    <table class="table table-striped">
        <thead>
        <tr><th>Name</th><th>Username</th><th>Role</th><th>Active</th><th class="text-end">Actions</th></tr>
        </thead>
        <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <td>@u.Person.FullName</td>
                <td>@u.Username</td>
                <td>@u.Role</td>
                <td>@(u.IsActive ? "Yes" : "No")</td>
                <td>
                    <div class="action-buttons">
                        <a asp-action="Edit" asp-route-id="@u.UserId" class="btn btn-sm btn-warning">Edit</a>
                        <form asp-action="Delete" asp-route-id="@u.UserId" method="post">
                            <button class="btn btn-sm btn-danger" type="submit">Deactivate</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
