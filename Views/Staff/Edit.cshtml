@model StaffFormViewModel
@{ ViewData["Title"] = "Edit Staff"; }
<form asp-action="Edit" method="post" class="card p-4 shadow-sm">
<input type="hidden" asp-for="UserId" /><input type="hidden" asp-for="PersonId" />
<partial name="_StaffForm" />
<div class="form-actions d-flex flex-wrap align-items-center mt-4 pt-3 border-top">
    <button class="btn btn-primary" type="submit">Update Staff & User</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</div>
</form>
@section Scripts{<partial name="_ValidationScriptsPartial"/>}
