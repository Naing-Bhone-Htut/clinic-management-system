@model StaffFormViewModel
@{ ViewData["Title"] = "Add Staff"; }
<form asp-action="Create" method="post" class="card p-4 shadow-sm">
<partial name="_StaffForm" />
<div class="form-actions d-flex flex-wrap align-items-center mt-4 pt-3 border-top">
    <button class="btn btn-primary" type="submit">Save Staff & User</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</div>
</form>
@section Scripts{<partial name="_ValidationScriptsPartial"/>}
