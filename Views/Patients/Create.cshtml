@model PatientFormViewModel
@{ ViewData["Title"] = "Add Patient"; }
<h4>Add Patient</h4>
<form asp-action="Create" method="post" class="card p-4 shadow-sm">
    <partial name="_PatientForm" model="Model" />
    <div class="form-actions d-flex flex-wrap align-items-center mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-primary">Save Patient</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
