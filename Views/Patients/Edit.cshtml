@model PatientFormViewModel
@{ ViewData["Title"] = "Edit Patient"; }
<h4>Edit Patient</h4>
<form asp-action="Edit" method="post" class="card p-4 shadow-sm">
    <input type="hidden" asp-for="PatientId" />
    <input type="hidden" asp-for="PersonId" />
    <input type="hidden" asp-for="AddressId" />
    <partial name="_PatientForm" model="Model" />
    <div class="form-actions d-flex flex-wrap align-items-center mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-primary">Update Patient</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
